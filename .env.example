# EVE Online SSO application credentials.
# Register an application at https://developers.eveonline.com/ with the
# callback URL http://localhost:5000/callback and the scopes listed in the
# README, then copy this file to .env and fill in the values below.

# Client ID from your EVE developer application.
EVE_CLIENT_ID=your_client_id_here

# Client Secret from your EVE developer application.
EVE_CLIENT_SECRET=your_client_secret_here

# Random string used to sign Flask sessions. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_random_secret_key_here

# OAuth callback URL. Must match exactly what you registered with EVE.
EVE_CALLBACK_URL=http://localhost:5000/callback
